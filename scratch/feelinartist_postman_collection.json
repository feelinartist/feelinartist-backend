  "item": [
    {
      "name": "1. Autenticación (Login y Registro)",
      "item": [
        {
          "name": "Login - Usuario Registrado (200 OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
                  "    console.log('Token y RefreshToken guardados automáticamente.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"correo\": \"artista_nuevo@gmail.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Inicia sesión con un correo existente. Retorna los detalles del usuario, el JWT Token (15 min) y el Refresh Token (7 días). Ambos tokens se guardan automáticamente en las variables de la colección."
          },
          "response": []
        },
        {
          "name": "Login - Usuario No Registrado (404 Not Found)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"correo\": \"no_registrado@gmail.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Retorna 404 si el usuario no ha sido registrado previamente con este correo. El frontend debe redirigir al flujo de registro (/auth/register)."
          },
          "response": []
        },
        {
          "name": "Login - Falta Correo (400 Bad Request)",
          "request": {
