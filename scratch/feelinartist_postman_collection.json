                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"correo\": \"artista_nuevo@gmail.com\",\n    \"nombre\": \"Artista de Prueba\",\n    \"imagen\": \"https://lh3.googleusercontent.com/a/ac123\",\n    \"zonaHoraria\": \"America/Lima\"\n}",
