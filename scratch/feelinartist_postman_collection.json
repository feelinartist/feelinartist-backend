              "mode": "raw",
              "raw": "{\n    \"rol\": \"ARTISTA\",\n    \"nombreUsuario\": \"artista_nuevo_user\",\n    \"categoria\": \"DJ\",\n    \"nombreArtistico\": \"DJ Carlos\",\n    \"generosFavoritos\": [\"Electrónica\", \"House\"],\n    \"codigoTelefono\": \"+51\",\n    \"numeroTelefono\": \"987654321\"\n}",
