    {
      "name": "2. Renovación de Token (Refresh)",
      "item": [
        {
          "name": "Refresh - Exitoso (200 OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "    pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
                  "    console.log('Nuevos Token y RefreshToken guardados automáticamente.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Renueva el Access Token y el Refresh Token. NO requiere Authorization header. IMPORTANTE: El refresh token anterior queda revocado (rotación). Los nuevos tokens se guardan automáticamente en las variables."
          },
          "response": []
        },
        {
          "name": "Refresh - Falta RefreshToken (400 Bad Request)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Retorna 400 con mensaje: 'Token de refresco requerido'."
          },
          "response": []
        },
        {
          "name": "Refresh - Token Inválido (401 Unauthorized)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"token_inexistente_o_inventado\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Retorna 401 con mensaje: 'Token de refresco inválido o expirado'. Ocurre cuando el token no existe, ya fue revocado (rotación), o expiró (7 días)."
          },
          "response": []
        },
        {
          "name": "Refresh - Token Ya Usado/Revocado (401 Unauthorized)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "PASOS PARA REPRODUCIR: 1) Ejecutar primero 'Refresh - Exitoso' para que el token actual se revoque. 2) Ejecutar esta request con el token viejo (que quedó revocado). Retorna 401 con mensaje: 'Token de refresco inválido o expirado'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Cerrar Sesión (Logout)",
      "item": [
        {
          "name": "Logout - Exitoso con RefreshToken (200 OK)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Cierra sesión completamente: agrega el Access Token a la lista negra (Redis) y revoca el Refresh Token (PostgreSQL). Retorna 200 con mensaje: 'Sesión cerrada exitosamente'. NOTA: Después de esto, usar el mismo JWT retornará 401 'Token inválido o expirado (sesión cerrada)'."
          },
          "response": []
        },
        {
          "name": "Logout - Sin RefreshToken en Body (200 OK)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Cierra sesión parcialmente: solo invalida el Access Token (blacklist en Redis). El Refresh Token NO se revoca y podría usarse para generar nuevos tokens. Se recomienda siempre enviar el refreshToken."
          },
          "response": []
        },
        {
          "name": "Logout - Sin Authorization Header (400 Bad Request)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Retorna 400 con mensaje: 'No se proporcionó token de autenticación'. Ocurre cuando no se envía el header Authorization con Bearer token."
          },
          "response": []
        },
        {
          "name": "Verificar Token Blacklisted Post-Logout (401 Unauthorized)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{jwt_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"nombreUsuario\": \"test_post_logout\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/usuarios/verificar-nombre-usuario",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios",
                "verificar-nombre-usuario"
              ]
            },
            "description": "PASOS PARA REPRODUCIR: 1) Ejecutar 'Logout - Exitoso con RefreshToken'. 2) Ejecutar esta request con el mismo JWT. Retorna 401 con mensaje: 'Token inválido o expirado (sesión cerrada)'. Esto demuestra que el token fue agregado a la blacklist de Redis."
          },
          "response": []
        }
      ]
    },
