generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                         String           @id @default(uuid())
  correo                     String           @unique
  nombreUsuario              String?          @unique
  nombre                     String?
  imagen                     String?
  rolId                      String?
  rol                        Rol?             @relation(fields: [rolId], references: [id])
  perfilArtista              PerfilArtista?
  perfilPublico              PerfilPublico?
  perfilDiscoteca            PerfilDiscoteca?
  // Datos de contacto y ubicación (centralizados desde perfiles)
  codigoTelefono             String?
  numeroTelefono             String?
  ciudad                     String?
  pais                       String?
  zonaHoraria                String?          // Obligatorio en nuevo registro, null hasta que haga login por primera vez
  generosFavoritos           String[]         // Géneros musicales favoritos del usuario
  creadoEn                   DateTime         @default(now())
  actualizadoEn              DateTime         @updatedAt
  creadoPor                  String?
  actualizadoPor             String?
  ultimoCambioNombreUsuario  DateTime?
  ultimoCambioNombre         DateTime?
  estado                     EstadoCuenta     @default(ACTIVO)
  fechaEliminacionProgramada DateTime?
  perfilCompletadoReconocido Boolean          @default(false)
  bloqueados                 Bloqueo[]        @relation("Bloqueador")
  bloqueadoPor               Bloqueo[]        @relation("Bloqueado")
}

enum EstadoCuenta {
  ACTIVO
  DESHABILITADO
  ELIMINACION_PENDIENTE
  BANEADO
}

model Bloqueo {
  id             String   @id @default(uuid())
  bloqueadorId   String
  bloqueadoId    String
  bloqueador     Usuario  @relation("Bloqueador", fields: [bloqueadorId], references: [id])
  bloqueado      Usuario  @relation("Bloqueado", fields: [bloqueadoId], references: [id])
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt
  creadoPor      String?
  actualizadoPor String?

  @@unique([bloqueadorId, bloqueadoId])
}

model PerfilPublico {
  id             String   @id @default(uuid())
  usuarioId      String   @unique
  usuario        Usuario  @relation(fields: [usuarioId], references: [id])
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt
  creadoPor      String?
  actualizadoPor String?
}

model Rol {
  id             String    @id @default(uuid())
  nombre         String    @unique
  usuarios       Usuario[]
  creadoEn       DateTime  @default(now())
  actualizadoEn  DateTime  @updatedAt
  creadoPor      String?
  actualizadoPor String?
}

model PerfilArtista {
  id        String  @id @default(uuid())
  usuarioId String  @unique
  biografia             String?
  fechaInicio           DateTime?             @db.Date
  tarifaPorHora         Decimal?
  moneda                String?
  lugaresConocidos      Json?
  redesSociales         ArtistaRedSocial[]
  metodosDonacion       ArtistaDonacion[]
  categoriaId           String
  categoria             CategoriaArtista      @relation(fields: [categoriaId], references: [id])
  musicQR               String?               // URL endpoint para peticiones de canciones
  pagoQR                String?               // QR de pago (Yape/Plin)
  nombreQR              String?
  urlPago               String?
  urlYoutubeFavorito    String?
  urlSoundCloudFavorito String?
  pedidosActivos        Boolean               @default(false)
  galeria               GaleriaArtista[]
  eventos               Evento[]
  pedidosCanciones      PedidoCancion[]
  estadisticasCanciones EstadisticasCancion[]
  seguidores            Seguidor[]
  usuario               Usuario               @relation(fields: [usuarioId], references: [id])
  creadoEn              DateTime              @default(now())
  actualizadoEn         DateTime              @updatedAt
  creadoPor             String?
  actualizadoPor        String?
}

model GaleriaArtista {
  id              String        @id @default(uuid())
  perfilArtistaId String
  urlImagen       String
  perfilArtista   PerfilArtista @relation(fields: [perfilArtistaId], references: [id])
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
  creadoPor       String?
  actualizadoPor  String?
}

model Evento {
  id               String          @id @default(uuid())
  perfilArtistaId  String
  titulo           String
  descripcion      String?
  horaInicio       DateTime        @default(now())
  horaFin          DateTime?
  activo           Boolean         @default(true)
  latitud          Float?
  longitud         Float?
  pedidosCanciones PedidoCancion[]
  perfilArtista    PerfilArtista   @relation(fields: [perfilArtistaId], references: [id])
  creadoEn         DateTime        @default(now())
  actualizadoEn    DateTime        @updatedAt
  creadoPor        String?
  actualizadoPor   String?
}

model PedidoCancion {
  id                String              @id @default(uuid())
  eventoId          String
  usuarioId         String? // Optional, for registered users
  itunesId          String? // Optional
  titulo            String? // For manual entry
  artista           String? // For manual entry
  genero            String? // Genre from iTunes or manual entry
  nombreSolicitante String?
  estado            EstadoPedidoCancion @default(PENDIENTE)
  evento            Evento              @relation(fields: [eventoId], references: [id])
  perfilArtistaId   String?
  perfilArtista     PerfilArtista?      @relation(fields: [perfilArtistaId], references: [id])
  creadoEn          DateTime            @default(now())
  actualizadoEn     DateTime            @updatedAt
  creadoPor         String?
  actualizadoPor    String?
}

enum EstadoPedidoCancion {
  PENDIENTE
  ACEPTADO
  RECHAZADO
}

model EstadisticasCancion {
  id       String  @id @default(uuid())
  itunesId String?
  titulo   String
  artista  String
  genero   String?

  // Contadores por artista
  perfilArtistaId String
  perfilArtista   PerfilArtista @relation(fields: [perfilArtistaId], references: [id])

  // Contadores (total = aceptados + rechazados)
  totalAceptados  Int @default(0)
  totalRechazados Int @default(0)

  // Metadata
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // Índice único por canción y artista
  @@unique([itunesId, perfilArtistaId])
  @@index([perfilArtistaId])
}

model Seguidor {
  id                String           @id @default(uuid())
  seguidorId        String
  artistaSeguidoId  String?
  perfilDiscotecaId String?
  artista           PerfilArtista?   @relation(fields: [artistaSeguidoId], references: [id])
  perfilDiscoteca   PerfilDiscoteca? @relation(fields: [perfilDiscotecaId], references: [id])
  creadoEn          DateTime         @default(now())
  actualizadoEn     DateTime         @updatedAt
  creadoPor         String?
  actualizadoPor    String?
}

model PerfilDiscoteca {
  id             String         @id @default(uuid())
  usuarioId      String         @unique
  // codigoTelefono, numeroTelefono, ciudad, pais, zonaHoraria → centralizados en Usuario
  nombreLocal    String?        // Nombre del local / establecimiento
  fechaFundacion DateTime?      @db.Date
  seguidores     Seguidor[]
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt
  creadoPor      String?
  actualizadoPor String?
}

model RedSocial {
  id            String             @id @default(uuid())
  nombre        String             @unique
  urlBase       String
  icono         String?
  estado        String             @default("ACTIVO")
  artistas      ArtistaRedSocial[]
  creadoEn      DateTime           @default(now())
  actualizadoEn DateTime           @updatedAt
}

model ArtistaRedSocial {
  id              String        @id @default(uuid())
  perfilArtistaId String
  redSocialId     String
  nombreUsuario   String
  perfilArtista   PerfilArtista @relation(fields: [perfilArtistaId], references: [id])
  redSocial       RedSocial     @relation(fields: [redSocialId], references: [id])
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
  creadoPor       String?
  actualizadoPor  String?

  @@unique([perfilArtistaId, redSocialId])
}

model MetodoDonacion {
  id            String            @id @default(uuid())
  nombre        String            @unique
  icono         String?
  estado        String            @default("ACTIVO")
  artistas      ArtistaDonacion[]
  creadoEn      DateTime          @default(now())
  actualizadoEn DateTime          @updatedAt
}

model ArtistaDonacion {
  id               String         @id @default(uuid())
  perfilArtistaId  String
  metodoDonacionId String
  numeroCuenta     String?
  perfilArtista    PerfilArtista  @relation(fields: [perfilArtistaId], references: [id])
  metodoDonacion   MetodoDonacion @relation(fields: [metodoDonacionId], references: [id])
  creadoEn         DateTime       @default(now())
  actualizadoEn    DateTime       @updatedAt
  creadoPor        String?
  actualizadoPor   String?

  @@unique([perfilArtistaId, metodoDonacionId])
}

model ConfiguracionSistema {
  id             String   @id @default(uuid())
  clave          String   @unique
  valor          String   @db.Text
  descripcion    String?
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt
  creadoPor      String?
  actualizadoPor String?
}

model CategoriaArtista {
  id             String          @id @default(uuid())
  nombre         String          @unique
  estado         String          @default("ACTIVO")
  artistas       PerfilArtista[]
  creadoEn       DateTime        @default(now())
  actualizadoEn  DateTime        @updatedAt
  creadoPor      String?
  actualizadoPor String?
}
